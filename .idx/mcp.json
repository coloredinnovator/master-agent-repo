{
  "mcpServers": {
    "firebase": {
      "command": "npx",
      "args": [
        "-y",
        "firebase-tools@latest",
        "experimental:mcp",
        "--only",
        "auth,firestore"
      ]
    },
    "terraform": {
      "command": "terraform",
      "args": [
        "-version"
      ]
    },
    "gcloud": {
      "command": "gcloud",
      "args": [
        "beta",
        "code",
        "dev"
      ]
    }
  }
}