# ============================================
# HERMES ECOSYSTEM - Environment Configuration
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to version control.

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hermes
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=hermes_db

# --- Kafka / Redpanda ---
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Neo4j ---
NEO4J_URL=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# --- LLM Configuration ---
# Set to "ollama" for local or "openai" for cloud
LLM_PROVIDER=ollama
OLLAMA_MODEL=hermes3
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-4o

# --- Google Cloud ---
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=marooncleanup
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- HuggingFace ---
HUGGINGFACE_API_KEY=hf_CHANGE_ME

# --- ChromaDB ---
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# --- Application ---
PORT=8080
LOG_LEVEL=INFO
